# Go build configurations
CGO_ENABLED = 0
GOBIN = /compass/bin

# Postgres connection details
POSTGRES_URL = postgres://compass:admin@compass-postgres:5432/compass?sslmode=disable

# Postgres container initialization
PGUSER = compass
POSTGRES_USER = ${PGUSER}
POSTGRES_PASSWORD = admin

# Redis connection details
REDIS_URL = redis://compass-redis:6379

# Keycloak connection details
KEYCLOAK_URL = http://compass-keycloak:8080
KEYCLOAK_REALM = compass-realm
KEYCLOAK_CLIENT_ID = compass-backend
KEYCLOAK_CLIENT_SECRET =
KEYCLOAK_ADMIN_USERNAME = admin
KEYCLOAK_ADMIN_PASSWORD = admin
KEYCLOAK_DB = keycloak
KEYCLOAK_DB_USER = keycloak
KEYCLOAK_DB_PASSWORD = keycloak
